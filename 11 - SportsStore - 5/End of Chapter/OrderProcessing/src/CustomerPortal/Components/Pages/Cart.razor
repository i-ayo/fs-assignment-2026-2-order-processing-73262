@page "/cart"
@inject CartService CartSvc
@inject NavigationManager Nav
@implements IDisposable

<div style="max-width:760px;margin:0 auto;">

<h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em;margin-bottom:24px;">Your Cart</h1>

@if (!CartSvc.Items.Any())
{
    <div class="empty-state">
        <div class="empty-icon">🛒</div>
        <div class="empty-title">Your cart is empty</div>
        <p class="empty-msg">Add some products to get started.</p>
        <a href="/shop" class="btn btn-primary">Continue Shopping</a>
    </div>
}
else
{
    <div class="card" style="margin-bottom:20px;">
        <table class="cart-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th style="text-align:right;">Unit Price</th>
                    <th style="text-align:center;">Qty</th>
                    <th style="text-align:right;">Line Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in CartSvc.Items)
                {
                    <tr>
                        <td style="font-weight:600;">@item.ProductName</td>
                        <td style="text-align:right;color:#8E8E93;">@item.UnitPrice.ToString("C")</td>
                        <td style="text-align:center;">
                            <div class="qty-stepper">
                                <button class="qty-btn"
                                        @onclick="() => CartSvc.SetQuantity(item.ProductId, item.Quantity - 1)">−</button>
                                <input type="number" class="qty-input"
                                       value="@item.Quantity"
                                       min="0"
                                       @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var q)) CartSvc.SetQuantity(item.ProductId, q); }" />
                                <button class="qty-btn"
                                        @onclick="() => CartSvc.SetQuantity(item.ProductId, item.Quantity + 1)">+</button>
                            </div>
                        </td>
                        <td style="text-align:right;font-weight:600;">@item.LineTotal.ToString("C")</td>
                        <td style="text-align:right;">
                            <button class="btn-remove" @onclick="() => CartSvc.RemoveItem(item.ProductId)">✕</button>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="cart-total-row">
                    <td colspan="3" style="text-align:right;font-weight:600;color:#8E8E93;font-size:13px;text-transform:uppercase;letter-spacing:.04em;">Order Total</td>
                    <td style="text-align:right;font-size:20px;font-weight:700;">@CartSvc.TotalPrice.ToString("C")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
        <a href="/shop" class="btn btn-secondary">← Continue Shopping</a>
        <a href="/checkout" class="btn btn-primary">Proceed to Checkout →</a>
    </div>
}

</div>

<style>
    .cart-table { width: 100%; border-collapse: collapse; }
    .cart-table th {
        padding: 12px 16px; font-size: 11px; font-weight: 600;
        text-transform: uppercase; letter-spacing: .04em;
        color: #8E8E93; border-bottom: 1px solid #E5E5EA;
    }
    .cart-table td { padding: 14px 16px; border-bottom: 1px solid #F2F2F7; font-size: 14px; }
    .cart-total-row td { border-top: 2px solid #E5E5EA; border-bottom: none; padding: 16px; }
    .qty-stepper { display: flex; align-items: center; gap: 0; width: 120px; margin: 0 auto; }
    .qty-btn {
        width: 32px; height: 32px; border: 1px solid #D1D1D6;
        background: #F2F2F7; cursor: pointer; font-size: 16px; color: #007AFF;
        border-radius: 8px 0 0 8px; display: flex; align-items: center; justify-content: center;
    }
    .qty-btn + .qty-input + .qty-btn { border-radius: 0 8px 8px 0; }
    .qty-btn:hover { background: #E5E5EA; }
    .qty-input {
        width: 56px; height: 32px; text-align: center; font-size: 14px; font-weight: 600;
        border: 1px solid #D1D1D6; border-left: none; border-right: none; outline: none;
    }
    .btn-remove {
        background: none; border: none; cursor: pointer;
        color: #FF3B30; font-size: 16px; padding: 4px 8px;
        border-radius: 6px; transition: background .12s;
    }
    .btn-remove:hover { background: #FFF1F0; }
</style>

@code {
    protected override void OnInitialized()
    {
        CartSvc.StateChanged += OnCartChanged;
    }

    private async void OnCartChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        CartSvc.StateChanged -= OnCartChanged;
    }
}
